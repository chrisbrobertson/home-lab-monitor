<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.homelab.monitor.agent</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/python3</string>
        <string>/Users/REPLACE_USER/hlab/agent/agent.py</string>
        <string>/Users/REPLACE_USER/hlab/agent/config.yml</string>
    </array>
    <key>WorkingDirectory</key>
    <string>/Users/REPLACE_USER/hlab</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/Users/REPLACE_USER/hlab/logs/agent.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/REPLACE_USER/hlab/logs/agent.err</string>
</dict>
</plist>
